# Backend API server – optional env vars (no .env required; defaults work if GroceryStore-script is a sibling folder).

# Absolute path to the GroceryStore-script folder. If omitted, defaults to ../GroceryStore-script from the backend folder.
# SCRAPER_DIR=C:\Users\LENOVO\Documents\scripts\Bussiness Scrapper\GroceryStore-script

# Where the scraper writes full/sample JSON/CSV. Defaults to GroceryStore-script/data/output and .../data/samples.
# OUTPUT_DIR=
# SAMPLES_DIR=

# Port for the API server (default 5000).
# PORT=5000
